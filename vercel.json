{
  "buildCommand": "vite build && npx esbuild api/_source.ts --bundle --platform=node --format=cjs --outfile=api/index.js --external:pg-native --external:bufferutil --external:utf-8-validate",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
